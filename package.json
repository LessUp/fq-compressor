{
  "name": "fq-compressor-docs",
  "private": true,
  "version": "0.1.0",
  "description": "Documentation for fq-compressor - Next.js + Nextra 3.x",
  "scripts": {
    "docs:install": "npm --prefix docs/website ci",
    "docs:build": "npm --prefix docs/website ci && npm --prefix docs/website run build",
