# Conan 2.x CI Clang Profile for fq-compressor
# =============================================================================
# Clang profile optimized for CI environments (GitHub Actions).
# Uses Clang 22 with libc++ for consistency with development environment (LLVM 22.1.0 stable).
#
# Usage (CI):
#   conan install . --profile=conan/profiles/ci-clang --build=missing
# =============================================================================

[settings]
os=Linux
arch=x86_64
compiler=clang
compiler.version=22
compiler.libcxx=libc++
compiler.cppstd=23
build_type=Release

[buildenv]
CC=clang
CXX=clang++

[conf]
tools.cmake.cmaketoolchain:generator=Ninja
tools.build:compiler_executables={"c": "clang", "cpp": "clang++"}
# Limit parallel jobs in CI to avoid resource exhaustion
tools.build:jobs=2
tools.build:skip_test=True
