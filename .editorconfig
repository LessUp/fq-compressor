# EditorConfig - https://editorconfig.org
# =============================================================================
# fq-compressor Editor Configuration
# =============================================================================
# This file ensures consistent coding styles across different editors and IDEs.
# Requirement 7.3: Code style enforcement
# =============================================================================

root = true

# 全局默认配置
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Markdown 文件保留尾部空格（用于换行）
[*.md]
trim_trailing_whitespace = false

# YAML 配置文件
[*.{yaml,yml}]
indent_style = space
indent_size = 2

# C/C++ 源文件 (aligned with .clang-format)
[*.{c,cc,cpp,cxx,h,hh,hpp,hxx,inl,ipp}]
max_line_length = 100

# Python 文件
[*.py]
max_line_length = 100

# TOML 配置文件 (Conan 等)
[*.toml]
indent_size = 2

# Makefile 必须使用 Tab
[Makefile]
indent_style = tab
indent_size = 4

