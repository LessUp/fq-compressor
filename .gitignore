# =============================================================================
# fq-compressor .gitignore
# =============================================================================

# 忽略所有的对象文件和库文件
*.o
*.a
*.so
*.dll
*.dylib
*.lib

# 忽略所有的编译输出目录
/cmake-build-debug/
/cmake-build-*/
/build/
/bin/
/obj/
/out/

# CTest 生成文件
/Testing/

# 忽略所有的临时文件
*.tmp
*.log
*.swp
*.bak

# 忽略所有的 IDE 配置文件
.vscode/*
!.vscode/settings.json
!.vscode/launch.json
!.vscode/tasks.json
!.vscode/extensions.json
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates

# 忽略所有的 CMake 生成文件
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
compile_commands.json
Makefile

# 忽略所有的自动生成的文档
docs/generated/
docs/api/

# 忽略所有的覆盖率报告
coverage/
*.gcda
*.gcno
*.gcov

# 忽略所有的 Conan 生成文件
conaninfo.txt
conanbuildinfo.*
conan.lock
conan_toolchain.cmake

# 忽略 vcpkg 安装目录
vcpkg_installed/

# 用户特定的 CMake 预设
CMakeUserPresets.json

# OS 特定文件
.DS_Store
Thumbs.db

# 编辑器/LSP 缓存
.clangd/

# 通用构建与安装输出
build*/
install/
install-*/

# 工具与分析报告
clang-tidy-fixes.yml
*.sarif
benchmark-*.json
benchmark-*.csv

# 覆盖率与分析数据
*.profraw
*.profdata

# Benchmark 结果（保留目录结构，排除临时结果）
benchmark_results/results/*.json
benchmark_results/reports/*.md
benchmark_results/reports/charts/*.svg
benchmark_results/reports/charts/*.png
benchmark_results/data/*.fastq
benchmark_results/data/*.fastq.gz
!benchmark_results/baselines/*.json

# docs/benchmark 生成文件（由 benchmark 脚本自动生成）
docs/benchmark/*.png
docs/benchmark/*.html
docs/benchmark/benchmark-report.md
docs/benchmark/results/

# Python 相关
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.env

# Honkit / GitBook
node_modules/
_book/
docs/.site/
.honkit/
.cache/

# Next.js build output
docs/website/.next/

# 压缩测试数据
*.fqc
*.fqc.idx

# OpenSpec - AI tool directories (configure per-project as needed)
# Most projects should track OpenSpec skills/commands for consistency
# Uncomment to ignore all AI tool configs:
.agent/
.amazonq/
.augment/
.bob/
.cline/
.clinerules/
.codebuddy/
.codex/
.continue/
.cospec/
.crush/
.cursor/
.factory/
.forge/
.gemini/
.iflow/
.junie/
.kilocode/
.kiro/
.lingma/
.omc/
.opencode/
.pi/
.qoder/
.qwen/
.roo/
.trae/
.windsurf/

# OpenSpec explorations (scratch/research docs, not tracked)
openspec/explorations/

# Reference projects (source code not tracked, but keep README)
ref-projects/*
!ref-projects/README.md