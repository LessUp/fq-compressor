{
    "version": 6,
    "cmakeMinimumRequired": { "major": 3, "minor": 28, "patch": 0 },
    "configurePresets": [
        {
            "name": "base",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_CXX_STANDARD": "23",
                "CMAKE_CXX_STANDARD_REQUIRED": "ON",
                "CMAKE_CXX_EXTENSIONS": "OFF",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        },
        {
            "name": "clang-base",
            "hidden": true,
            "inherits": "base",
            "cacheVariables": {
                "CMAKE_C_COMPILER": "clang",
                "CMAKE_CXX_COMPILER": "clang++",
                "CMAKE_CXX_FLAGS": "-stdlib=libc++",
                "CMAKE_EXE_LINKER_FLAGS": "-stdlib=libc++ -lc++abi",
                "CMAKE_SHARED_LINKER_FLAGS": "-stdlib=libc++ -lc++abi"
            }
        },
        {
            "name": "clang-debug",
            "displayName": "Clang Debug",
            "inherits": "clang-base",
            "toolchainFile": "${sourceDir}/build/${presetName}/build/Debug/generators/conan_toolchain.cmake",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_CXX_FLAGS_DEBUG": "-g -DDEBUG"
            }
        },
        {
            "name": "clang-release",
            "displayName": "Clang Release",
            "inherits": "clang-base",
            "toolchainFile": "${sourceDir}/build/${presetName}/build/Release/generators/conan_toolchain.cmake",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_INTERPROCEDURAL_OPTIMIZATION": "ON"
            }
        },
        {
            "name": "clang-asan",
            "displayName": "Clang ASan+UBSan",
            "inherits": "clang-base",
            "toolchainFile": "${sourceDir}/build/${presetName}/build/Debug/generators/conan_toolchain.cmake",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_CXX_FLAGS_DEBUG": "-g -O1 -DDEBUG -fsanitize=address,undefined -fno-sanitize=vptr -fno-omit-frame-pointer",
                "CMAKE_EXE_LINKER_FLAGS_DEBUG": "-stdlib=libc++ -lc++abi -fsanitize=address,undefined",
                "CMAKE_SHARED_LINKER_FLAGS_DEBUG": "-stdlib=libc++ -lc++abi -fsanitize=address,undefined"
            }
        },
        {
            "name": "clang-tsan",
            "displayName": "Clang TSan",
            "inherits": "clang-base",
            "toolchainFile": "${sourceDir}/build/${presetName}/build/Debug/generators/conan_toolchain.cmake",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_CXX_FLAGS_DEBUG": "-g -O1 -DDEBUG -fsanitize=thread -fno-omit-frame-pointer",
                "CMAKE_EXE_LINKER_FLAGS_DEBUG": "-stdlib=libc++ -lc++abi -fsanitize=thread",
                "CMAKE_SHARED_LINKER_FLAGS_DEBUG": "-stdlib=libc++ -lc++abi -fsanitize=thread"
            }
        }
    ],
    "buildPresets": [
        { "name": "clang-debug", "configurePreset": "clang-debug" },
        { "name": "clang-release", "configurePreset": "clang-release" },
        { "name": "clang-asan", "configurePreset": "clang-asan" },
        { "name": "clang-tsan", "configurePreset": "clang-tsan" }
    ],
    "testPresets": [
        {
            "name": "clang-debug",
            "configurePreset": "clang-debug",
            "output": { "outputOnFailure": true },
            "execution": { "noTestsAction": "error" }
        },
        {
            "name": "clang-release",
            "configurePreset": "clang-release",
            "output": { "outputOnFailure": true },
            "execution": { "noTestsAction": "error" }
        },
        {
            "name": "clang-asan",
            "configurePreset": "clang-asan",
            "output": { "outputOnFailure": true, "verbosity": "verbose" },
            "execution": { "noTestsAction": "error", "stopOnFailure": true }
        },
        {
            "name": "clang-tsan",
            "configurePreset": "clang-tsan",
            "output": { "outputOnFailure": true, "verbosity": "verbose" },
            "execution": { "noTestsAction": "error", "stopOnFailure": true }
        }
    ]
}
