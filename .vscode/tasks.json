{
    "version": "2.0.0",
    "tasks": [
        // =====================================================================
        // Conan 依赖安装
        // =====================================================================
        {
            "label": "Conan: Install (Clang Debug)",
            "type": "shell",
            "command": "conan install . --build=missing -s build_type=Debug -s compiler=clang -of build/clang-debug/build/Debug",
            "group": "none",
            "problemMatcher": [],
            "detail": "安装 Clang Debug 构建的 Conan 依赖"
        },
        {
            "label": "Conan: Install (Clang Release)",
            "type": "shell",
            "command": "conan install . --build=missing -s build_type=Release -s compiler=clang -of build/clang-release/build/Release",
            "group": "none",
            "problemMatcher": [],
            "detail": "安装 Clang Release 构建的 Conan 依赖"
        },
        // =====================================================================
        // CMake Configure
        // =====================================================================
        {
            "label": "CMake: Configure clang-debug",
            "type": "shell",
            "command": "cmake --preset clang-debug",
            "group": "none",
            "problemMatcher": "$gcc",
            "detail": "CMake 配置 Clang Debug preset"
        },
        {
            "label": "CMake: Configure clang-release",
            "type": "shell",
            "command": "cmake --preset clang-release",
            "group": "none",
            "problemMatcher": "$gcc",
            "detail": "CMake 配置 Clang Release preset"
        },
        {
            "label": "CMake: Configure clang-asan",
            "type": "shell",
            "command": "cmake --preset clang-asan",
            "group": "none",
            "problemMatcher": "$gcc",
            "detail": "CMake 配置 Clang AddressSanitizer preset"
        },
        {
            "label": "CMake: Configure clang-tsan",
            "type": "shell",
            "command": "cmake --preset clang-tsan",
            "group": "none",
            "problemMatcher": "$gcc",
            "detail": "CMake 配置 Clang ThreadSanitizer preset"
        },
        // =====================================================================
        // CMake Build
        // =====================================================================
        {
            "label": "CMake: Build clang-debug",
            "type": "shell",
            "command": "cmake --build --preset clang-debug",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$gcc",
            "detail": "构建 Clang Debug"
        },
        {
            "label": "CMake: Build clang-release",
            "type": "shell",
            "command": "cmake --build --preset clang-release",
            "group": "build",
            "problemMatcher": "$gcc",
            "detail": "构建 Clang Release"
        },
        {
            "label": "CMake: Build clang-asan",
            "type": "shell",
            "command": "cmake --build --preset clang-asan",
            "group": "build",
            "problemMatcher": "$gcc",
            "detail": "构建 Clang AddressSanitizer"
        },
        {
            "label": "CMake: Build clang-tsan",
            "type": "shell",
            "command": "cmake --build --preset clang-tsan",
            "group": "build",
            "problemMatcher": "$gcc",
            "detail": "构建 Clang ThreadSanitizer"
        },
        // =====================================================================
        // CTest 测试
        // =====================================================================
        {
            "label": "CTest: Run clang-debug",
            "type": "shell",
            "command": "ctest --preset clang-debug --output-on-failure",
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "problemMatcher": "$gcc",
            "detail": "运行 Clang Debug 全部测试"
        },
        {
            "label": "CTest: Run clang-asan",
            "type": "shell",
            "command": "ctest --preset clang-asan --output-on-failure",
            "group": "test",
            "problemMatcher": "$gcc",
            "detail": "运行 Clang ASan 测试 (内存错误检测)"
        },
        {
            "label": "CTest: Run clang-tsan",
            "type": "shell",
            "command": "ctest --preset clang-tsan --output-on-failure",
            "group": "test",
            "problemMatcher": "$gcc",
            "detail": "运行 Clang TSan 测试 (数据竞争检测)"
        },
        // =====================================================================
        // 代码质量
        // =====================================================================
        {
            "label": "Lint: clang-tidy (当前文件)",
            "type": "shell",
            "command": "clang-tidy -p build/clang-debug ${file}",
            "group": "none",
            "problemMatcher": "$gcc",
            "detail": "对当前打开的文件运行 clang-tidy 静态分析"
        },
        // =====================================================================
        // 清理
        // =====================================================================
        {
            "label": "Clean: clang-debug",
            "type": "shell",
            "command": "cmake --build --preset clang-debug --target clean",
            "group": "none",
            "problemMatcher": [],
            "detail": "清理 Clang Debug 构建产物"
        },
        {
            "label": "Clean: All builds",
            "type": "shell",
            "command": "rm -rf build/*/",
            "group": "none",
            "problemMatcher": [],
            "detail": "清理所有构建目录"
        },
        // =====================================================================
        // 脚本快捷方式
        // =====================================================================
        {
            "label": "Script: Build (clang-debug)",
            "type": "shell",
            "command": "./scripts/build.sh clang-debug",
            "group": "build",
            "problemMatcher": "$gcc",
            "detail": "通过项目脚本执行 Clang Debug 构建"
        },
        {
            "label": "Script: Test (clang-debug)",
            "type": "shell",
            "command": "./scripts/test.sh clang-debug",
            "group": "test",
            "problemMatcher": "$gcc",
            "detail": "通过项目脚本执行 Clang Debug 测试"
        },
        {
            "label": "Script: Lint format-check",
            "type": "shell",
            "command": "./scripts/lint.sh format-check",
            "group": "none",
            "problemMatcher": [],
            "detail": "通过项目脚本检查代码格式"
        },
        {
            "label": "Script: Lint (clang-debug)",
            "type": "shell",
            "command": "./scripts/lint.sh lint clang-debug",
            "group": "none",
            "problemMatcher": "$gcc",
            "detail": "通过项目脚本执行静态分析"
        },
        // =====================================================================
        // 组合任务
        // =====================================================================
        {
            "label": "Full: Build & Test (clang-debug)",
            "dependsOrder": "sequence",
            "dependsOn": [
                "CMake: Build clang-debug",
                "CTest: Run clang-debug"
            ],
            "group": "test",
            "problemMatcher": [],
            "detail": "完整流程：构建 + 测试 (Clang Debug)"
        },
        {
            "label": "Full: Configure & Build (clang-debug)",
            "dependsOrder": "sequence",
            "dependsOn": [
                "CMake: Configure clang-debug",
                "CMake: Build clang-debug"
            ],
            "group": "build",
            "problemMatcher": [],
            "detail": "完整流程：配置 + 构建 (Clang Debug)"
        }
    ]
}
